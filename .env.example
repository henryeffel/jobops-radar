APP_NAME=JobOps Radar
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=false

# Local development fallback (works without Docker)
DATABASE_URL=sqlite:///./jobops.db

# PostgreSQL production target (also used by docker-compose.yml)
# DATABASE_URL=postgresql+psycopg://jobops:jobops@localhost:5432/jobops

JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
SARAMIN_ACCESS_KEY=
SARAMIN_API_BASE_URL=https://oapi.saramin.co.kr
LLM_API_KEY=
LLM_MOCK_MODE=true
